# .env.development.example
NODE_ENV=development
PORT=3001  # Different port for development

# Use local PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ajoti_dev?schema=public"

# Local Redis
REDIS_HOST="localhost"
REDIS_PORT=6379

# Development URLs
APP_BASE_URL="http://localhost:3001"

# Development email (use MailHog or similar for local testing)
MAIL_HOST="localhost"
MAIL_PORT=1025
MAIL_USER=""
MAIL_PASS=""
MAIL_FROM="dev@ajoti.local"

# Development secrets (can be simpler for dev)
JWT_ACCESS_SECRET="dev_access_secret_change_in_production"
JWT_REFRESH_SECRET="dev_refresh_secret_change_in_production"

# Less restrictive throttling for development
THROTTLE_TTL=60000
THROTTLE_LIMIT=120  # Higher limit for development