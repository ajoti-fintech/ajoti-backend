# ============================================
# APPLICATION CONFIGURATION
# ============================================

# Application Environment
NODE_ENV=development
PORT=3000

# CORS Configuration
CORS_ORIGIN=*


# ============================================
# DATABASE CONFIGURATION
# ============================================

# PostgreSQL Database URL
# Format: postgresql://username:password@host:port/database_name?schema=public
DATABASE_URL="postgresql://username:password@localhost:5432/database_name?schema=public"


# ============================================
# JWT AUTHENTICATION
# ============================================

# JWT Secrets - Generate secure random strings (min 64 chars)
# Use: openssl rand -hex 64
JWT_ACCESS_SECRET="your_generated_access_secret_here_min_64_characters"
JWT_REFRESH_SECRET="your_generated_refresh_secret_here_min_64_characters"

# JWT Token Expiration
JWT_ACCESS_EXPIRES_IN="15m"    # 15 minutes
JWT_REFRESH_EXPIRES_IN="30d"   # 30 days


# ============================================
# APPLICATION URLs
# ============================================

# Base URL for API
APP_BASE_URL="http://localhost:3000"


# ============================================
# EMAIL SERVICE (SMTP)
# ============================================

# SMTP Server Configuration
MAIL_HOST="smtp.gmail.com"
MAIL_PORT="587"
MAIL_USER="your-email@gmail.com"
MAIL_PASS="your-app-specific-password"  # Use App Password for Gmail
MAIL_FROM="no-reply@yourapp.com"


# ============================================
# OTP & VERIFICATION
# ============================================

# OTP Expiration Time
OTP_EXPIRES_MINUTES="10"


# ============================================
# RATE LIMITING (THROTTLING)
# ============================================

# Throttle Configuration (Redis-based)
THROTTLE_TTL=60000             # Time window in milliseconds (1 minute)
THROTTLE_LIMIT=60              # Max requests per time window
REDIS_THROTTLE_PREFIX="throttle:"


# ============================================
# REDIS CONFIGURATION
# ============================================

# Redis Server
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""              # Optional password


# ============================================
# SUPER ADMIN ACCOUNT
# ============================================

# Initial Super Admin Credentials
# These are used to create the first admin user on application startup
SUPERADMIN_EMAIL="admin@yourapp.com"
SUPERADMIN_PASSWORD="ChangeMe123!"  # Change on first login
