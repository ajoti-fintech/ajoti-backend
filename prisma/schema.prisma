generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Wallet {
  id             String          @id @default(uuid())
  userId         String          @unique @map("user_id")
  currency       String          @default("NGN")
  status         WalletStatus    @default(ACTIVE)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  ledgerEntries  LedgerEntry[]
  systemWallet   SystemWallet?
  transactions   Transaction[]
  virtualAccount VirtualAccount?
  buckets        WalletBucket[]
  user           User            @relation(fields: [userId], references: [id])

  @@map("wallets")
}

model LedgerEntry {
  id            String           @id @default(uuid())
  walletId      String           @map("wallet_id")
  reference     String
  entryType     EntryType        @map("entry_type")
  amount        BigInt
  balanceBefore BigInt           @map("balance_before")
  balanceAfter  BigInt           @map("balance_after")
  metadata      Json?
  createdAt     DateTime         @default(now()) @map("created_at")
  bucketType    BucketType?      @map("bucket_type")
  movementType  MovementType     @map("movement_type")
  sourceId      String           @map("source_id")
  sourceType    LedgerSourceType @map("source_type")
  wallet        Wallet           @relation(fields: [walletId], references: [id])

  @@unique([walletId, reference, sourceType, sourceId])
  @@index([walletId, createdAt(sort: Desc)])
  @@index([walletId, sourceType, sourceId])
  @@map("ledger_entries")
}

model WalletBucket {
  id             String     @id @default(uuid())
  walletId       String     @map("wallet_id")
  bucketType     BucketType @map("bucket_type")
  reservedAmount BigInt     @default(0) @map("reserved_amount")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  sourceId       String     @map("source_id")
  wallet         Wallet     @relation(fields: [walletId], references: [id])

  @@unique([walletId, bucketType, sourceId])
  @@map("wallet_buckets")
}

model Transaction {
  id          String            @id @default(uuid())
  walletId    String            @map("wallet_id")
  provider    String            @default("FLUTTERWAVE")
  reference   String            @unique
  amount      BigInt
  currency    String            @default("NGN")
  status      TransactionStatus
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  completedAt DateTime?         @map("completed_at")
  metadata    Json?
  type        TransactionType   @map("transaction_type")
  wallet      Wallet            @relation(fields: [walletId], references: [id])

  @@index([reference])
  @@index([type])
  @@index([status])
  @@index([walletId])
  @@map("transactions")
}

model WebhookEvent {
  id          String   @id @default(uuid())
  provider    String
  eventId     String   @unique @map("event_id")
  processedAt DateTime @default(now()) @map("processed_at")
  payload     Json?

  @@index([eventId])
  @@index([provider])
  @@map("webhook_events")
}

model VirtualAccount {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  walletId      String   @unique @map("wallet_id")
  accountNumber String   @map("account_number")
  bankName      String   @map("bank_name")
  accountName   String   @map("account_name")
  flwRef        String   @unique @map("flw_ref")
  orderRef      String   @unique @map("order_ref")
  txRef         String   @unique @map("tx_ref")
  currency      String   @default("NGN")
  isActive      Boolean  @default(true) @map("is_active")
  isPermanent   Boolean  @default(true) @map("is_permanent")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet        Wallet   @relation(fields: [walletId], references: [id])

  @@map("virtual_accounts")
}

model SystemWallet {
  id        String           @id @default(uuid())
  type      SystemWalletType @unique
  walletId  String           @unique @map("wallet_id")
  createdAt DateTime         @default(now()) @map("created_at")
  wallet    Wallet           @relation(fields: [walletId], references: [id])

  @@map("system_wallets")
}

model RoscaCircle {
  id                    String               @id @default(uuid())
  name                  String
  description           String?
  adminId               String               @map("admin_id")
  contributionAmount    BigInt               @map("contribution_amount")
  currency              String               @default("NGN")
  frequency             CycleFrequency
  durationCycles        Int                  @map("duration_cycles")
  currentCycle          Int                  @default(1) @map("current_cycle")
  maxSlots              Int                  @map("max_slots")
  filledSlots           Int                  @default(0) @map("filled_slots")
  visibility            CircleVisibility     @default(PUBLIC)
  payoutLogic           PayoutLogic          @default(COMBINED) @map("payout_logic")
  status                CircleStatus         @default(DRAFT)
  collateralPercentage  Float                @default(10.0) @map("collateral_percentage")
  latePenaltyPercent    Float                @default(2.0) @map("late_penalty_percent")
  preStartExitPenalty   BigInt?              @map("pre_start_exit_penalty")
  minTrustScoreRequired Int                  @default(0) @map("min_trust_score_required")
  startDate             DateTime?            @map("start_date")
  startDateRangeMin     DateTime?            @map("start_date_range_min")
  startDateRangeMax     DateTime?            @map("start_date_range_max")
  recruitmentDeadline   DateTime?            @map("recruitment_deadline")
  autoStartOnFull       Boolean              @default(false) @map("auto_start_on_full")
  verifiedAt            DateTime?            @map("verified_at")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")
  admin                 User                 @relation(fields: [adminId], references: [id])
  contributions         RoscaContribution[]
  schedules             RoscaCycleSchedule[]
  memberships           RoscaMembership[]
  payouts               RoscaPayout[]

  @@map("rosca_circles")
}

model RoscaMembership {
  id                 String              @id @default(uuid())
  circleId           String              @map("circle_id")
  userId             String              @map("user_id")
  status             MembershipStatus    @default(PENDING)
  payoutPosition     Int?                @map("payout_position")
  collateralAmount   BigInt              @map("collateral_amount")
  collateralReleased Boolean             @default(false) @map("collateral_released")
  completedCycles    Int                 @default(0) @map("completed_cycles")
  totalLatePayments  Int                 @default(0) @map("total_late_payments")
  totalPenaltiesPaid BigInt              @default(0) @map("total_penalties_paid")
  joinedAt           DateTime?           @map("joined_at")
  approvedAt         DateTime?           @map("approved_at")
  completedAt        DateTime?           @map("completed_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  contributions      RoscaContribution[]
  circle             RoscaCircle         @relation(fields: [circleId], references: [id])
  user               User                @relation(fields: [userId], references: [id])

  @@unique([circleId, userId])
  @@map("rosca_memberships")
}

model RoscaCycleSchedule {
  id                   String         @id @default(uuid())
  circleId             String         @map("circle_id")
  cycleNumber          Int            @map("cycle_number")
  contributionDeadline DateTime       @map("contribution_deadline")
  payoutDate           DateTime       @map("payout_date")
  status               ScheduleStatus @default(UPCOMING)
  recipientId          String?        @map("recipient_id")
  obsoletedAt          DateTime?      @map("obsoleted_at")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  circle               RoscaCircle    @relation(fields: [circleId], references: [id])
  recipient            User?          @relation(fields: [recipientId], references: [id])
  payout               RoscaPayout?

  @@unique([circleId, cycleNumber, obsoletedAt])
  @@map("rosca_cycle_schedules")
}

model RoscaContribution {
  id                   String          @id @default(uuid())
  circleId             String          @map("circle_id")
  membershipId         String          @map("membership_id")
  userId               String          @map("user_id")
  cycleNumber          Int             @map("cycle_number")
  amount               BigInt
  penaltyAmount        BigInt          @default(0) @map("penalty_amount")
  ledgerDebitId        String?         @map("ledger_debit_id")
  transactionReference String?         @map("transaction_reference")
  paidAt               DateTime        @default(now()) @map("paid_at")
  createdAt            DateTime        @default(now()) @map("created_at")
  circle               RoscaCircle     @relation(fields: [circleId], references: [id])
  membership           RoscaMembership @relation(fields: [membershipId], references: [id])
  user                 User            @relation(fields: [userId], references: [id])

  @@unique([circleId, membershipId, cycleNumber])
  @@map("rosca_contributions")
}

model RoscaPayout {
  id                String             @id @default(uuid())
  circleId          String             @map("circle_id")
  scheduleId        String             @unique @map("schedule_id")
  recipientId       String             @map("recipient_id")
  amount            BigInt
  status            PayoutStatus       @default(PENDING)
  provider          String?            @default("FLUTTERWAVE")
  providerReference String?            @map("provider_reference")
  internalReference String?            @map("internal_reference")
  poolDebitId       String?            @map("pool_debit_id")
  recipientCreditId String?            @map("recipient_credit_id")
  reversalDebitId   String?            @map("reversal_debit_id")
  reversalCreditId  String?            @map("reversal_credit_id")
  processedAt       DateTime?          @map("processed_at")
  failedAt          DateTime?          @map("failed_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  circle            RoscaCircle        @relation(fields: [circleId], references: [id])
  recipient         User               @relation(fields: [recipientId], references: [id])
  schedule          RoscaCycleSchedule @relation(fields: [scheduleId], references: [id])

  @@map("rosca_payouts")
}

model UserTrustStats {
  id                      String   @id @default(uuid())
  userId                  String   @unique @map("user_id")
  trustScore              Int      @default(50)
  completionRate          Float    @default(0)
  totalRoscasJoined       Int      @default(0) @map("total_roscas_joined")
  totalRoscasCompleted    Int      @default(0) @map("total_roscas_completed")
  totalOnTimePayments     Int      @default(0) @map("total_on_time_payments")
  totalLatePayments       Int      @default(0) @map("total_late_payments")
  totalDefaults           Int      @default(0) @map("total_defaults")
  consecutiveLatePayments Int      @default(0) @map("consecutive_late_payments")
  lastUpdated             DateTime @default(now()) @map("last_updated")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")
  user                    User     @relation(fields: [userId], references: [id])

  @@map("user_trust_stats")
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String   @map("actor_id")
  actorType  String   @map("actor_type")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  before     Json?
  after      Json?
  reason     String?
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  password            String
  role                Role                 @default(MEMBER)
  isVerified          Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  dob                 DateTime             @default(now())
  firstName           String
  gender              Gender
  lastName            String
  phone               String
  otps                OtpCode[]
  refreshTokens       RefreshToken[]
  profile             UserProfile?
  kyc                 KYC?
  roscaCircles        RoscaCircle[]
  roscaContributions  RoscaContribution[]
  roscaCycleSchedules RoscaCycleSchedule[]
  roscaMemberships    RoscaMembership[]
  roscaPayouts        RoscaPayout[]
  savedBankAccounts   SavedBankAccount[]
  userTrustStats      UserTrustStats?
  virtualAccount      VirtualAccount?
  wallet              Wallet?
}

model UserProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KYC {
  id                    String    @id @default(uuid())
  userId                String    @unique
  status                KYCStatus @default(NOT_SUBMITTED)
  step                  KYCStep   @default(NIN_REQUIRED)
  nin                   String?   @db.VarChar(11)
  bvn                   String?   @db.VarChar(11)
  ninVerifiedAt         DateTime?
  bvnVerifiedAt         DateTime?
  nextOfKinName         String?   @db.VarChar(255)
  nextOfKinRelationship String?   @db.VarChar(255)
  nextOfKinPhone        String?   @db.VarChar(20)
  rejectionReason       String?
  submittedAt           DateTime?
  reviewedAt            DateTime?
  reviewedBy            String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([step])
  @@index([userId, status])
  @@map("kyc")
}

model OtpCode {
  id        String     @id @default(uuid())
  userId    String
  purpose   OTPPurpose
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  revokedAt DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SavedBankAccount {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  bankCode      String   @map("bank_code")
  bankName      String   @map("bank_name")
  accountNumber String   @map("account_number")
  accountName   String   @map("account_name")
  recipientCode String?  @map("recipient_code")
  isDefault     Boolean  @default(false) @map("is_default")
  metadata      Json?    @default("{}")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, accountNumber, bankCode])
  @@map("saved_bank_accounts")
}

enum WalletStatus {
  ACTIVE
  RESTRICTED
  SUSPENDED
  CLOSED
}

enum EntryType {
  CREDIT
  DEBIT
  RESERVE
  RELEASE
}

enum LedgerSourceType {
  TRANSACTION
  ROSCA_CIRCLE
  CONTRIBUTION
  COLLATERAL_RESERVE
  COLLATERAL_RELEASE
  PENALTY
  EXIT_PENALTY
  TRUST_ADJUSTMENT
  ADMIN_ADJUSTMENT
  REVERSAL
  SYSTEM
}

enum BucketType {
  ROSCA
  TARGET
  FIXED
  REMITTANCE
  MAIN
}

enum MovementType {
  FUNDING
  WITHDRAWAL
  TRANSFER
}

enum TransactionType {
  FUNDING
  WITHDRAWAL
  FUNDING_CARD
  FUNDING_USSD
  FUNDING_BANKTRANSFER
  FUNDING_ACCOUNT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum SystemWalletType {
  PLATFORM_POOL
  RECIPIENT_BASE
}

enum CycleFrequency {
  WEEKLY
  BI_WEEKLY
  MONTHLY
}

enum CircleVisibility {
  PUBLIC
  PRIVATE
}

enum PayoutLogic {
  RANDOM_DRAW
  SEQUENTIAL
  TRUST_SCORE
  COMBINED
  ADMIN_ASSIGNED
}

enum CircleStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum MembershipStatus {
  PENDING
  ACTIVE
  REJECTED
  COMPLETED
  EXITED
}

enum ScheduleStatus {
  UPCOMING
  COMPLETED
  SKIPPED
  CANCELLED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum Role {
  MEMBER
  ADMIN
  SUPERADMIN
}

enum OTPPurpose {
  VERIFICATION
  RESET_PASSWORD
}

enum KYCStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

enum KYCStep {
  NIN_REQUIRED
  BVN_REQUIRED
  NOK_REQUIRED
  SUBMITTED
}

enum Gender {
  MALE
  FEMALE
}
